# VARIÁVEIS DE AMBIENTE — MAANDHOO CLUB
# Copie este arquivo para .env.local e preencha os valores

# ============================================
# BANCO DE DADOS — SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI
# String de conexão Postgres (pooler do Supabase)
# Importante: se houver "$" na senha, escape como "\$" no .env
DATABASE_URL=postgresql://postgres.SEU_PROJETO:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
POSTGRES_URL=${DATABASE_URL}

# ============================================
# AUTENTICAÇÃO — SESSÕES ADMIN E CLIENTE
# Gere com: openssl rand -base64 32
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=GERE_UMA_SECRET_FORTE_AQUI_COM_32_CHARS

# ============================================
# LGPD — SEGURANÇA E PRIVACIDADE
# ============================================
# Salt para hash anonimizado de IPs no registro de consentimento de cookies.
# LGPD: IP é dado pessoal — nunca armazenamos o IP bruto, apenas o hash SHA-256.
# Gere um valor único para produção com: openssl rand -hex 32
# Adicione também no painel de Environment Variables da Vercel.
IP_HASH_SALT=GERE_UM_SALT_UNICO_AQUI_COM_OPENSSL_RAND_HEX_32

# ============================================
# MERCADO PAGO — configurar na conta do cliente
# (não configurar até fechamento com o cliente)
# ============================================
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MERCADOPAGO_ACCESS_TOKEN=APP_USR-0000000000000000-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
MERCADOPAGO_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET

# ============================================
# EMAIL — RESEND
# https://resend.com → API Keys
# ============================================
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM="Maandhoo Club <noreply@bravosbrasil.com.br>"

# ============================================
# SITE
# ============================================
NEXT_PUBLIC_SITE_URL=https://maandhoo.com
NEXT_PUBLIC_SITE_NAME=Maandhoo Club
NEXT_PUBLIC_URL=http://localhost:3000

# ============================================
# WHATSAPP — LINK BASE
# ============================================
WHATSAPP_NUMBER=5547999300283

# ============================================
# STORAGE — SUPABASE (configurado automaticamente)
# ============================================
NEXT_PUBLIC_STORAGE_URL=https://SEU_PROJETO.supabase.co/storage/v1/object/public

# VARIÁVEIS DE AMBIENTE — MAANDHOO CLUB
# Copie este arquivo para .env.local e preencha os valores

# ============================================
# BANCO DE DADOS — SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI
# String de conexao Postgres (pooler do Supabase)
# Importante: se houver "$" na senha, escape como "\$" no .env
DATABASE_URL=postgresql://postgres.SEU_PROJETO:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
# Alias util para ferramentas que esperam POSTGRES_URL
POSTGRES_URL=${DATABASE_URL}

# ============================================
# AUTENTICAÇÃO — NEXTAUTH
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=GERE_UMA_SECRET_FORTE_AQUI_COM_32_CHARS

# ============================================
# MERCADO PAGO — PESSOA JURÍDICA
# ============================================
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MERCADOPAGO_ACCESS_TOKEN=APP_USR-0000000000000000-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX
MERCADOPAGO_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET

# ============================================
# EMAIL — NODEMAILER
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=contato@maandhoo.com
EMAIL_PASS=SUA_SENHA_APP_GMAIL
EMAIL_FROM="Maandhoo Club <contato@maandhoo.com>"

# ============================================
# WHATSAPP — LINK BASE
# ============================================
WHATSAPP_NUMBER=5547999300283

# ============================================
# SITE
# ============================================
NEXT_PUBLIC_SITE_URL=https://maandhoo.com
NEXT_PUBLIC_SITE_NAME=Maandhoo Club
# URL base usada por rotas server-side internas
NEXT_PUBLIC_URL=http://localhost:3000

# ============================================
# STORAGE — SUPABASE (configurado automaticamente)
# ============================================
NEXT_PUBLIC_STORAGE_URL=https://SEU_PROJETO.supabase.co/storage/v1/object/public
